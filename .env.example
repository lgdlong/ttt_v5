# ==============================================================================
# 1. DATABASE CONFIGURATION
# ==============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=ttt_project
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable

# ==============================================================================
# 2. IDENTITY SERVICE (BETTER AUTH SERVER)
# ==============================================================================
# PROD: https://the1struleoffightclub.top
# DEV: http://localhost:8081
BETTER_AUTH_URL=http://localhost:8081
BETTER_AUTH_SECRET=generate_a_long_random_string
IDENTITY_PORT=8081

# ==============================================================================
# 3. BACKEND SERVICE (GO)
# ==============================================================================
BACKEND_PORT=8080
GIN_MODE=debug

# ==============================================================================
# 4. FRONTEND SERVICE (VITE CLIENT)
# ==============================================================================
# PROD API: https://the1struleoffightclub.top
# DEV API: http://localhost:8080 (backend router handles /api/v1 prefix)
VITE_API_URL=http://localhost:8080

# PROD AUTH: https://the1struleoffightclub.top
# DEV AUTH: http://localhost:8081
VITE_AUTH_URL=http://localhost:8081

# ==============================================================================
# 5. THIRD PARTY & OAUTH
# ==============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
YOUTUBE_API_KEY=your_youtube_api_key
